<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Conteúdo da Tela -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMeusAnuncios"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- NAVBAR -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="@color/white"
        android:weightSum="5">

        <!-- HOME -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/nav_home_icon"
                android:src="@drawable/ic_home"
                android:layout_width="24dp"
                android:layout_height="24dp" />

            <TextView
                android:id="@+id/nav_home_text"
                android:text="Home"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- LOCAIS -->
        <LinearLayout
            android:id="@+id/nav_locais"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/nav_locais_icon"
                android:src="@drawable/ic_location"
                android:layout_width="24dp"
                android:layout_height="24dp" />

            <TextView
                android:id="@+id/nav_locais_text"
                android:text="Locais"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- AVISOS -->
        <LinearLayout
            android:id="@+id/nav_avisos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/nav_avisos_icon"
                android:src="@drawable/ic_notifications"
                android:layout_width="24dp"
                android:layout_height="24dp" />

            <TextView
                android:id="@+id/nav_avisos_text"
                android:text="Avisos"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- MEUS ANÚNCIOS -->
        <LinearLayout
            android:id="@+id/nav_meus_anuncios"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/nav_meus_anuncios_icon"
                android:src="@drawable/ic_menu_mylocation"
                android:layout_width="24dp"
                android:layout_height="24dp" />

            <TextView
                android:id="@+id/nav_meus_anuncios_text"
                android:text="Meus Anúncios"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- PERFIL -->
        <LinearLayout
            android:id="@+id/nav_perfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/nav_perfil_icon"
                android:src="@drawable/ic_person"
                android:layout_width="24dp"
                android:layout_height="24dp" />

            <TextView
                android:id="@+id/nav_perfil_text"
                android:text="Perfil"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>



    </LinearLayout>

</LinearLayout>
